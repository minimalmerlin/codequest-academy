# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://DEIN_PROJEKT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Supabase Project Ref ──────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → General → Reference ID
SUPABASE_PROJECT_REF=abcdefghijklmnop

# ─── Gemini API Key ────────────────────────────────────────────────────────────
# Get free key from: https://aistudio.google.com → Get API key
GEMINI_API_KEY=AIzaSyBiF2bBeE5UlzJ-XyRMWTZoRPtJ3VXkGhA

# ─── Setup Instructions ────────────────────────────────────────────────────────
# 1. Create project at https://supabase.com (kostenlos)
# 2. Run supabase/schema.sql in the Supabase SQL Editor
# 3. Copy URL + anon key from Project Settings → API
# 4. Copy Project Ref from Project Settings → General
# 5. Get Gemini API Key from https://aistudio.google.com
# 6. Copy this file to .env.local and fill in your values
# 7. Run: ./deploy-edge.sh  (deploys the AI Edge Function)
# 8. In Vercel: Settings → Environment Variables → paste SUPABASE_URL + ANON_KEY
